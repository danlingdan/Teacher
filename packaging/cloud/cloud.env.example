# Copy to /etc/sqlteacher/cloud.env. Do not commit the real file.
SQLTEACHER_CLOUD_PORT=18080
SQLTEACHER_CLOUD_DB=/opt/sqlteacher/data/cloud.db
# Set only during first deployment, then remove or rotate these values.
SQLTEACHER_CLOUD_BOOTSTRAP_ADMIN_EMAIL=admin@example.edu
SQLTEACHER_CLOUD_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-random-12-character-minimum-password
