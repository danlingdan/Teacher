<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sqlteacher.desktop.controller.ExerciseProgressController"
            styleClass="exercise-page">
    <top>
        <VBox spacing="6" styleClass="title-area">
            <padding><Insets top="20" right="24" bottom="14" left="24"/></padding>
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="6">
                    <Label text="学习进度" styleClass="page-title"/>
                    <Label text="v0.3 基础口径；常见错误、时间趋势和 CSV 看板将在 v0.4 提供。" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="刷新" onAction="#onRefresh" styleClass="refresh-button"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="12" styleClass="progress-content">
            <TilePane prefColumns="6" hgap="10" vgap="10">
                <VBox styleClass="progress-card"><Label text="会话" styleClass="model-status"/><Label fx:id="sessionsLabel" text="0" styleClass="progress-value"/></VBox>
                <VBox styleClass="progress-card"><Label text="尝试" styleClass="model-status"/><Label fx:id="attemptsLabel" text="0" styleClass="progress-value"/></VBox>
                <VBox styleClass="progress-card"><Label text="提交通过率" styleClass="model-status"/><Label fx:id="passRateLabel" text="0%" styleClass="progress-value"/></VBox>
                <VBox styleClass="progress-card"><Label text="平均提交耗时" styleClass="model-status"/><Label fx:id="durationLabel" text="0 ms" styleClass="progress-value"/></VBox>
                <VBox styleClass="progress-card"><Label text="提示次数" styleClass="model-status"/><Label fx:id="hintsLabel" text="0" styleClass="progress-value"/></VBox>
                <VBox styleClass="progress-card"><Label text="已完成题目" styleClass="model-status"/><Label fx:id="completedLabel" text="0" styleClass="progress-value"/></VBox>
            </TilePane>
            <TableView fx:id="progressTable" styleClass="result-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="titleColumn" text="题目" prefWidth="220"/>
                    <TableColumn fx:id="knowledgeColumn" text="知识点" prefWidth="150"/>
                    <TableColumn fx:id="attemptsColumn" text="尝试" prefWidth="80"/>
                    <TableColumn fx:id="failuresColumn" text="失败提交" prefWidth="100"/>
                    <TableColumn fx:id="passedColumn" text="状态" prefWidth="90"/>
                    <TableColumn fx:id="lastAttemptColumn" text="最后尝试" prefWidth="130"/>
                </columns>
            </TableView>
            <Label fx:id="statusLabel" visible="false" managed="false" wrapText="true"/>
        </VBox>
    </center>
</BorderPane>
